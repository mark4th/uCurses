{
    "screen" :
    {
        "windows" :
        {
            "window" :
            {
                "width"  : 100%,             // a percentage of the screen
                "height" : 100%,             // width and height

                "xco"    : 1,               // within bounds of backdrop border
                "yco"    : 1,

                "border-type" : "uC_BDR_SINGLE",

                "attribs" :
                {
                    "gray-fg" : 23,
                    "bg"      : 0
                },

                "border-attribs" :
                {
                    "gray-fg" : 9,
                    "gray-bg" : 4
                },

                "flags" :
                {
                   "flag" : "uC_WIN_BOXED",
                   "flag" : "uC_WIN_LOCKED"
                }
            }
        }
    }
}
